# Copy this file to .env for local development.
# If `dotenv` is installed, `node server.js` will load it automatically.
# Without `dotenv`, the app still reads variables from the runtime environment.

# App port
PORT=2616

# Set a long random secret in non-development environments
SESSION_SECRET=change-this-to-a-long-random-secret

# Use "production" when deploying behind HTTPS
NODE_ENV=development

# Enable automatic Sequelize schema alteration only when intentionally migrating schema
DB_SYNC_ALTER=false
